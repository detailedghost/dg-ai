{
	"extends": "./.wxt/tsconfig.json",
	"compilerOptions": {
		"baseUrl": ".",
		"types": ["bun-types", "chrome"],
		"paths": {
			"@": ["."],
			"@/*": ["./*"],
			"~": ["."],
			"~/*": ["./*"],
			"@@": ["."],
			"@@/*": ["./*"],
			"~~": ["."],
			"~~/*": ["./*"],
			"@dg/common": ["../common/src/index.ts"],
			"@dg/common/*": ["../common/src/*"]
		}
	}
}
