{
	"name": "dg-ai-extension",
	"description": "Source for the dg-ai-extension web extension (built with WXT).",
	"private": true,
	"type": "module",
	"version": "1.1.0",
	"scripts": {
		"postinstall": "wxt prepare",
		"dev": "wxt",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"compile": "tsc --noEmit"
	},
	"devDependencies": {
		"typescript": "^5",
		"wxt": "^0.20.0"
	}
}
